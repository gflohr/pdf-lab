{
	"name": "@pdf-lab/fontkit",
	"version": "1.1.0",
	"description": "An advanced font engine for Node and the browser",
	"type": "module",
	"main": "dist/fontkit.umd.js",
	"unpkg": "dist/fontkit.umd.min.js",
	"module": "dist/fontkit.es.js",
	"types": "fontkit.d.ts",
	"scripts": {
		"clean": "rimraf --glob dist \"src/**/trie.ts\" \"src/**/trie-indic.ts\" \"src/**/trie-use.ts\" \"src/**/indic.ts\" \"src/**/use.ts\"",
		"generate:data": "pnpm exec tsx scripts/gen-trie.ts && pnpm exec tsx scripts/gen-use.ts && pnpm exec tsx scripts/gen-indic.ts",
		"build": "pnpm run clean && pnpm run generate:data && rollup -c",
		"dev": "rollup -c -w",
		"check": "biome check",
		"check:fix": "biome check --write",
		"prepublishOnly": "pnpm run build",
		"test": "vitest --run",
		"test:changed": "vitest --changed origin/main --passWithNoTests",
		"test:watch": "vitest",
		"test:cov": "vitest --coverage.enabled --run",
		"test:cov-changed": "vitest --coverage.enabled --run --changed origin/main --passWithNoTests"
	},
	"dependencies": {
		"pako": "^2.1.0"
	},
	"devDependencies": {
		"@pdf-lib/brotli": "^0.0.0",
		"@pdf-lib/restructure": "^0.0.1",
		"@pdf-lib/unicode-properties": "^0.0.1",
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-inject": "^5.0.5",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-swc": "^0.4.1",
		"@rollup/plugin-terser": "^1.0.0",
		"@types/deep-equal": "^1.0.4",
		"@types/node": "^25.9.3",
		"@types/pako": "^2.0.4",
		"base64-arraybuffer": "^1.0.2",
		"buffer": "^6.0.3",
		"clone": "^2.1.2",
		"codepoints": "^1.3.0",
		"deep-equal": "^2.2.3",
		"dfa": "^1.2.0",
		"esdoc": "^1.1.0",
		"esdoc-es7-plugin": "0.0.3",
		"iconv-lite": "^0.7.2",
		"rimraf": "^6.1.3",
		"rollup": "^4.62.2",
		"rollup-plugin-polyfill-node": "^0.13.0",
		"rollup-plugin-typescript2": "^0.37.0",
		"tiny-inflate": "^1.0.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"unicode-trie": "^2.0.0",
		"vitest": "^4.1.9"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/gflohr/pdf-lab.git"
	},
	"keywords": [
		"opentype",
		"font",
		"typography",
		"subset",
		"emoji",
		"glyph",
		"layout"
	],
	"author": "Guido Flohr <guido.flohr@cantanea.com>",
	"contributors": [
		"Devon Govett <devongovett@gmail.com> (http://badassjs.com/)",
		"Andrew Dillon <andrew.dillon.j@gmail.com>"
	],
	"bugs": {
		"url": "https://github.com/gflohr/pdf-lab/issues"
	},
	"license": "MIT",
	"homepage": "https://github.com/gflohr/pdf-lab/packages/fontkit#readme"
}
